{
  "name": "entra-login-api",
  "version": "1.0.0",
  "description": "Backend-only Web API for Microsoft Entra ID guest invitation and role-based onboarding.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:unit": "cross-env NODE_ENV=test jest --runInBand tests/unit",
    "test:integration": "cross-env NODE_ENV=test jest --runInBand tests/integration",
    "test:integration:postgres": "cross-env NODE_ENV=test TEST_DB_DIALECT=postgres jest --runInBand tests/integration",
    "db:migrate": "node scripts/migrate.js",
    "db:migrate:undo": "node scripts/migrateUndo.js"
  },
  "keywords": [
    "express",
    "microsoft-graph",
    "entra-id",
    "sequelize",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@azure/msal-node": "^2.12.0",
    "axios": "^1.8.4",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "pg": "^8.13.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.6",
    "umzug": "^3.8.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "sqlite3": "^5.1.7",
    "supertest": "^7.1.0"
  }
}
