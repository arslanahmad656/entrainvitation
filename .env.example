NODE_ENV=development
PORT=3000
LOG_LEVEL=info
LOG_SQL=false

DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=entra_login
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_STORAGE=

ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
API_CLIENT_ID=00000000-0000-0000-0000-000000000000
AUTH_AUDIENCE=api://00000000-0000-0000-0000-000000000000
AUTH_CLOCK_TOLERANCE_SECONDS=5

GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_SECRET=replace-me
GRAPH_SCOPE=https://graph.microsoft.com/.default
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
INVITE_REDIRECT_URL=https://app.example.com/post-login
SERVICE_PRINCIPAL_CACHE_TTL_MS=300000
